# ── LLM backend ─────────────────────────────────────────────────────────────────
LLM_BACKEND=claude              # "claude" or "ollama"
LLM_COOLDOWN_SECONDS=30         # min seconds between LLM calls per camera

# Claude (used when LLM_BACKEND=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=256

# Ollama (used when LLM_BACKEND=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5vl:32b
OLLAMA_TIMEOUT=60               # seconds before giving up on a local model response

# ── Alerts ───────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=            # Discord channel webhook URL
DISCORD_TIMEOUT=15              # seconds before giving up on Discord webhook

# ── Cameras & web viewer ─────────────────────────────────────────────────────────
CAMERA_URLS=rtsp://user:pass@192.168.1.100/stream1   # comma-separated
FLASK_PORT=5000

# ── Motion detection ─────────────────────────────────────────────────────────────
MOTION_THRESHOLD=5000           # changed pixels to trigger LLM analysis
MOG2_HISTORY=500                # frames MOG2 uses to build background model
MOG2_VAR_THRESHOLD=50           # sensitivity: lower = more detections, more noise

# ── Image quality (1–100) ────────────────────────────────────────────────────────
JPEG_QUALITY_ANALYSIS=80        # frame sent to LLM (lower = faster upload)
JPEG_QUALITY_ALERT=85           # snapshot sent via Telegram
JPEG_QUALITY_STREAM=70          # web MJPEG stream (lower = smoother stream)
JPEG_QUALITY_STORAGE=90         # frame saved to disk

# ── Performance ──────────────────────────────────────────────────────────────────
MONITOR_LOOP_INTERVAL=0.1       # seconds between detection checks per camera
DASHBOARD_REFRESH_RATE=2.0      # terminal dashboard redraws per second
